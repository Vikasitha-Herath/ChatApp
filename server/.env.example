# ─── SERVER ───────────────────────────────────────────
PORT=5000

# ─── DATABASE ─────────────────────────────────────────
# Local:   mongodb://localhost:27017/chatapp
# Atlas:   mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/chatapp
MONGODB_URI=mongodb://localhost:27017/chatapp

# ─── JWT ──────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_string
JWT_EXPIRE=7d

# ─── EMAIL (Gmail) ────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_16_char_app_password
EMAIL_FROM=ChatApp <your_email@gmail.com>

# ─── STRIPE ───────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# ─── APP CONFIG ───────────────────────────────────────
FREE_MESSAGE_LIMIT=3
PRIVATE_CHAT_PRICE=99

# ─── CORS (set to your Vercel URL in production) ──────
CLIENT_URL=http://localhost:3000
